APP_NAME=AgroEscudo API
# local: desarrollo normal; demo: habilita acciones guiadas de presentacion; production: las deshabilita
ENVIRONMENT=local

# Local sin Docker
DATABASE_URL=sqlite:///./agroescudo_dev.db

# PostgreSQL con Docker
# DATABASE_URL=postgresql+psycopg://agroescudo:agroescudo@localhost:5432/agroescudo

# URL publica del backend para documentacion operativa y scripts externos
API_URL=http://127.0.0.1:8010

# Cambiar antes de cualquier despliegue compartido o productivo
JWT_SECRET=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Notificaciones externas. Desactivadas por defecto hasta cargar credenciales reales.
NOTIFICATIONS_DRY_RUN=true
WHATSAPP_ENABLED=false
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v20.0
WHATSAPP_TEMPLATE_ALERT=
WHATSAPP_TEMPLATE_LANGUAGE=es

TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=

FCM_ENABLED=false
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_FILE=
FIREBASE_SERVICE_ACCOUNT_JSON=

# Asistente operativo. Para Gemini habilitar ambos flags y mantener la key solo en backend.
AI_ENABLED=false
AGRO_ASSISTANT_LLM_ENABLED=false
AI_PROVIDER=rules
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
AI_REQUEST_TIMEOUT_SECONDS=30
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
