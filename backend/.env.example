APP_NAME=AgroEscudo API
# local: desarrollo normal; demo: habilita acciones guiadas de presentacion; production: las deshabilita
ENVIRONMENT=local

# Local sin Docker
DATABASE_URL=sqlite:///./agroescudo_dev.db
API_URL=http://127.0.0.1:8010
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Nube Render + Neon/Supabase
# ENVIRONMENT=demo
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/DB
# API_URL=https://TU-SERVICIO.onrender.com
# CORS_ORIGINS=*
# JWT_SECRET=CAMBIAR_POR_SECRETO_LARGO

# PostgreSQL con Docker local
# DATABASE_URL=postgresql+psycopg://agroescudo:agroescudo@localhost:5432/agroescudo

# Cambiar antes de cualquier despliegue compartido o productivo
JWT_SECRET=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=480
IOT_SIGNATURE_WINDOW_SECONDS=300
AGRO_ASSISTANT_LLM_ENABLED=false
# Opcional para seed local de gateway; en piloto real provisionar fuera del repositorio.
AGRO_SEED_GATEWAY_SECRET=
# En nube mantener false. Activar solo para inicializar una base vacía de demo.
RUN_SEED_ON_START=false
# Opción destructiva para desarrollo: elimina lecturas, alertas y bitácora de la empresa seed.
RESET_OPERATIONAL_DATA_ON_SEED=false

# Notificaciones externas. Quedan desactivadas hasta cargar credenciales reales.
NOTIFICATIONS_DRY_RUN=true
NOTIFICATION_MAX_RETRIES=3
WHATSAPP_ENABLED=false
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v20.0
WHATSAPP_TEMPLATE_ALERT_NAME=
WHATSAPP_TEMPLATE_LANGUAGE=es

TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=

FCM_ENABLED=false
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_FILE=
# En Render usar JSON completo o base64; nunca versionar el service account.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Asistente operativo. Gemini se llama solo desde backend y siempre conserva fallback por reglas.
AI_ENABLED=false
AI_PROVIDER=rules
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
AI_REQUEST_TIMEOUT_SECONDS=30
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Email transaccional P0. En local EMAIL_ENABLED=false devuelve tokens preview para pruebas.
EMAIL_ENABLED=false
EMAIL_PROVIDER=resend
EMAIL_FROM=
EMAIL_API_KEY=
EMAIL_REPLY_TO=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
PUBLIC_APP_URL=http://localhost:3000

# Storage permanente para fotos/firmas/PDFs. Local usa var/uploads/ gitignored.
STORAGE_PROVIDER=local
MAX_UPLOAD_BYTES=10485760
S3_ENDPOINT_URL=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=

# Control Center y soporte
DEVICE_OFFLINE_AFTER_MINUTES=120
PUBLIC_LANDING_URL=
DEMO_LEAD_URL=
PUBLIC_WHATSAPP_URL=
SUPPORT_WHATSAPP=
SUPPORT_EMAIL=soporte@agroescudo.com
SUPPORT_HOURS=Lunes a viernes, 08:30-18:00
SUPPORT_TIMEZONE=America/La_Paz

# Observabilidad opcional
SENTRY_ENABLED=false
SENTRY_DSN=
RELEASE_VERSION=control-center-v1.0.0
